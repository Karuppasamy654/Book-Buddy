NODE_ENV=production
# For local dev you can leave DATABASE_URL empty to use SQLite
# When deployed on Render/Heroku, this will be injected automatically.
# Example for local PostgreSQL testing:
# DATABASE_URL=postgres://user:password@localhost:5432/bookbuddy

# Frontend URL when serving static files (optional, defaults to http://localhost:3000)
FRONTEND_URL=https://your-app.onrender.com

# Application port (Render will set PORT automatically)
PORT=5000

# JWT secret for authentication
JWT_SECRET=super_secret_key_change_me

# Stripe secret key (if you use Stripe payments)
STRIPE_SECRET_KEY=sk_test_<redacted>

# Razorpay key
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX
